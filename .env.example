# Скопіюй у .env і за потреби заповни. Файл .env у .gitignore.
DEBUG=True
# Для реального деплою згенеруй власний: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=dev-insecure-key-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# DATABASE_URL — для ЛОКАЛЬНОГО запуску (pytest/runserver) проти compose-БД на порту 5433.
# Контейнер web усередині compose будує свій DSN на host=db:5432 автоматично.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/myshop
POSTGRES_DB=myshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Email (dev: у консоль)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=shop@example.com
ADMIN_EMAIL=admin@example.com
# Реальна доставка — розкоментуй і заповни (приклад: Mailtrap-пісочниця, ловить лист у веб-інбоксі):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# Базовий URL для абсолютних посилань у листах (у проді — реальний домен):
SITE_URL=http://localhost:8000

# Celery-брокер (асинхронна відправка листів через Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
