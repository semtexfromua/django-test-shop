# Copy to .env and fill in as needed. .env is in .gitignore.
DEBUG=True
# For a real deployment generate your own: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=dev-insecure-key-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# DATABASE_URL — for LOCAL runs (pytest/runserver) against the compose DB on port 5433.
# The web container inside compose builds its own DSN on host=db:5432 automatically.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/myshop
POSTGRES_DB=myshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Email (dev: to the console)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=shop@example.com
ADMIN_EMAIL=admin@example.com
# Real delivery — uncomment and fill in (example: Mailtrap sandbox, catches mail in a web inbox):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=sandbox.smtp.mailtrap.io
# EMAIL_PORT=2525
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
# Base URL for absolute links in emails (in prod — your real domain):
SITE_URL=http://localhost:8000

# Celery broker (async email delivery via Redis)
CELERY_BROKER_URL=redis://localhost:6379/0
