# Скопіюй у .env і за потреби заповни. Файл .env у .gitignore.
DEBUG=True
SECRET_KEY=dev-insecure-key-change-me
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# DATABASE_URL — для ЛОКАЛЬНОГО запуску (pytest/runserver) проти compose-БД на порту 5433.
# Контейнер web усередині compose будує свій DSN на host=db:5432 автоматично.
DATABASE_URL=postgres://postgres:postgres@localhost:5433/myshop
POSTGRES_DB=myshop
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Email (dev: у консоль)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=shop@example.com
ADMIN_EMAIL=admin@example.com
